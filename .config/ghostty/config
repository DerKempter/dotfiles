background-opacity = 0.80
background-blur = 25

theme = Catppuccin Mocha

font-family = JetBrainsMono Nerd Font
font-size = 11
font-thicken = true
font-feature = +liga,+calt,+dlig
cursor-style = block
cursor-style-blink = false
cursor-color = cell-foreground
cursor-text = cell-background
unfocused-split-opacity = 0.75
split-divider-color = #b4befe

mouse-hide-while-typing = true

confirm-close-surface = false
window-decoration = none
window-padding-x = 12
window-padding-y = 12
window-padding-balance = true
window-theme = dark

auto-update = check
auto-update-channel = stable

# extras
shell-integration-features = ssh-env,ssh-terminfo,no-cursor
copy-on-select = clipboard

command = nu --login

# Create Splits in all directions
keybind = ctrl+alt+i=new_split:up
keybind = ctrl+alt+k=new_split:down
keybind = ctrl+alt+j=new_split:left
keybind = ctrl+alt+l=new_split:right

# Close the active split
keybind = ctrl+alt+u=close_surface

# Resize Splits
keybind = ctrl+alt+shift+i=resize_split:up,10
keybind = ctrl+alt+shift+k=resize_split:down,10
keybind = ctrl+alt+shift+j=resize_split:left,10
keybind = ctrl+alt+shift+l=resize_split:right,10

# Navigation
keybind = alt+i=goto_split:top
keybind = alt+k=goto_split:bottom
keybind = alt+j=goto_split:left
keybind = alt+l=goto_split:right
